        <color red="128" green="128" blue="128">
        </color>
      </off_color>
      <on_color>
        <color red="0" green="200" blue="0">
        </color>
      </on_color>
    </widget>
    <widget type="label" version="2.0.0">
      <name>PolarityPosText</name>
      <text>+</text>
      <x>375</x>
      <y>98</y>
      <width>20</width>
      <height>25</height>
