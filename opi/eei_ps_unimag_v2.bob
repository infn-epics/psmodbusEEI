<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>EEI PS UNIMAG Interface</name>
  <macros>
    <P>BTF:MAG:EEI</P>
    <R>QUATB201</R>
  </macros>
  <width>650</width>
  <height>900</height>
  <background_color>
    <color red="240" green="240" blue="240">
    </color>
  </background_color>
  
  <!-- Title Bar -->
  <widget type="rectangle" version="2.0.0">
    <name>TitleBar</name>
    <width>650</width>
    <height>60</height>
    <line_color>
      <color red="0" green="51" blue="102">
      </color>
    </line_color>
    <background_color>
      <color red="0" green="51" blue="102">
      </color>
    </background_color>
  </widget>
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <text>$(R) - EEI UNIMAG</text>
    <x>20</x>
    <y>10</y>
    <width>400</width>
    <height>40</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="28.0">
      </font>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255">
      </color>
    </foreground_color>
  </widget>
  <widget type="led" version="2.0.0">
    <name>StatusLED</name>
    <pv_name>$(P):$(R):STAT_FAULTY</pv_name>
    <x>560</x>
    <y>12</y>
    <width>35</width>
    <height>35</height>
    <off_color>
      <color red="0" green="200" blue="0">
      </color>
    </off_color>
    <on_color>
      <color red="255" green="0" blue="0">
      </color>
    </on_color>
  </widget>
  <widget type="label" version="2.0.0">
    <name>PrefixLabel</name>
    <text>$(P)</text>
    <x>520</x>
    <y>35</y>
    <width>120</width>
    <height>20</height>
    <font>
      <font family="Liberation Sans" style="ITALIC" size="10.0">
      </font>
    </font>
    <foreground_color>
      <color red="200" green="200" blue="220">
      </color>
    </foreground_color>
    <horizontal_alignment>2</horizontal_alignment>
  </widget>

  <!-- Readings Group -->
  <widget type="group" version="3.0.0">
    <name>ReadingsGroup</name>
    <x>15</x>
    <y>75</y>
    <width>620</width>
    <height>150</height>
    <style>1</style>
    <foreground_color>
      <color red="0" green="51" blue="102">
      </color>
    </foreground_color>
    
    <widget type="label" version="2.0.0">
      <name>CurrentLabel</name>
      <text>Current (signed)</text>
      <x>20</x>
      <y>15</y>
      <width>140</width>
      <height>25</height>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>CurrentDisplay</name>
      <pv_name>$(P):$(R):CURRENT_SIGNED_RB</pv_name>
      <x>20</x>
      <y>40</y>
      <width>180</width>
      <height>50</height>
      <font>
        <font family="Liberation Sans" style="BOLD" size="32.0">
        </font>
      </font>
      <foreground_color>
        <color red="0" green="80" blue="160">
        </color>
      </foreground_color>
      <background_color>
        <color red="230" green="240" blue="250">
        </color>
      </background_color>
      <format>1</format>
      <precision>3</precision>
      <horizontal_alignment>2</horizontal_alignment>
      <vertical_alignment>1</vertical_alignment>
    </widget>
    <widget type="label" version="2.0.0">
      <name>CurrentUnit</name>
      <text>A</text>
      <x>205</x>
      <y>55</y>
      <width>40</width>
      <height>35</height>
      <font>
        <font family="Liberation Sans" style="BOLD" size="24.0">
        </font>
      </font>
      <foreground_color>
        <color red="0" green="80" blue="160">
        </color>
      </foreground_color>
    </widget>
    
    <widget type="label" version="2.0.0">
      <name>VoltageLabel</name>
      <text>Voltage</text>
      <x>280</x>
      <y>15</y>
      <width>80</width>
      <height>25</height>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>VoltageDisplay</name>
      <pv_name>$(P):$(R):VOLT_RB</pv_name>
      <x>280</x>
      <y>40</y>
      <width>120</width>
      <height>50</height>
      <font>
        <font family="Liberation Sans" style="BOLD" size="24.0">
        </font>
      </font>
      <foreground_color>
        <color red="100" green="100" blue="100">
        </color>
      </foreground_color>
      <format>1</format>
      <precision>1</precision>
      <horizontal_alignment>2</horizontal_alignment>
      <vertical_alignment>1</vertical_alignment>
    </widget>
    <widget type="label" version="2.0.0">
      <name>VoltageUnit</name>
      <text>V</text>
      <x>405</x>
      <y>55</y>
      <width>30</width>
      <height>35</height>
      <font>
        <font family="Liberation Sans" style="BOLD" size="18.0">
        </font>
      </font>
      <foreground_color>
        <color red="100" green="100" blue="100">
        </color>
      </foreground_color>
    </widget>
    
    <widget type="label" version="2.0.0">
      <name>StateLabel</name>
      <text>State</text>
      <x>470</x>
      <y>15</y>
      <width>80</width>
      <height>25</height>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>StateDisplay</name>
      <pv_name>$(P):$(R):STATUS_RB</pv_name>
      <x>460</x>
      <y>40</y>
      <width>140</width>
      <height>50</height>
      <font>
        <font family="Liberation Sans" style="BOLD" size="16.0">
        </font>
      </font>
      <background_color>
        <color red="220" green="220" blue="220">
        </color>
      </background_color>
      <horizontal_alignment>1</horizontal_alignment>
      <vertical_alignment>1</vertical_alignment>
      <rules>
        <rule name="StateColor" prop_id="background_color" out_exp="false">
          <exp bool_exp="pv0==0">
            <value>
              <color red="128" green="128" blue="128">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0==1">
            <value>
              <color red="255" green="255" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0==2">
            <value>
              <color red="0" green="200" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0==3">
            <value>
              <color red="255" green="165" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0==4">
            <value>
              <color red="0" green="150" blue="255">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0&gt;=5">
            <value>
              <color red="255" green="0" blue="0">
              </color>
            </value>
          </exp>
          <pv_name>$(P):$(R):STATUS_RB</pv_name>
        </rule>
      </rules>
    </widget>
    
    <widget type="label" version="2.0.0">
      <name>PolarityLabel</name>
      <text>Polarity</text>
      <x>280</x>
      <y>100</y>
      <width>60</width>
      <height>20</height>
    </widget>
    <widget type="led" version="2.0.0">
      <name>PolarityPosLED</name>
      <pv_name>$(P):$(R):STAT_POLARITY_POS</pv_name>
